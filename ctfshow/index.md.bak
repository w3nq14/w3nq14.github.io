    mov edx, 2          ; 将2赋值给edx
    mov eax, [ecx + edx*2]  ; 将ecx+edx*2所指向的地址的值赋值给eax
```

如注释`，ecx=msg=`080490E8`，edx=2，eax=[ecx+edx*2]`

