```
## /page.php<?php    error_reporting(0);include __DIR__.DIRECTORY_SEPARATOR.'system36d/util/dbutil.php';$id = isset($_GET['id'])?$_GET['id']:'1';// 转义'来实现防注入$id = addslashes($id);$name = db::get_username($id);?>
