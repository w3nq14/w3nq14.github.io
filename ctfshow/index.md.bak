```php
$query = new MongoDB\Driver\Query($data);
$cursor = $manager->executeQuery('ctfshow.ctfshow_user', $query)->toArray();
      
//无过滤
if(count($cursor)>0){
    $ret['msg']='登陆成功';
    array_push($ret['data'], $flag);
}
